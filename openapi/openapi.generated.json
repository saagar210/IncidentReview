    "/rpc/check_workspace_migration_status": {
      "post": {
        "description": "Return migration drift status for selected workspace DB.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dbPath": {
                    "type": "string",
                    "minLength": 1
