{
  "name": "incidentreview",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lean": "bash scripts/dev-lean.sh",
    "build": "tsc && vite build",
    "build:ui": "tsc --noEmit --project tsconfig.ui.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "ui:lint": "pnpm lint && stylelint \"src/**/*.{css,scss}\" --allow-empty-input",
    "ui:typecheck": "tsc --noEmit --project tsconfig.ui.json",
    "ui:gate:static": "pnpm ui:lint && pnpm ui:typecheck",
    "ui:test:visual": "playwright test tests/ui --grep @visual",
    "ui:test:a11y": "playwright test tests/ui --grep @a11y",
    "ui:gate:regression": "pnpm ui:test:visual && pnpm ui:test:a11y",
    "ui:gate": "pnpm ui:gate:static && pnpm ui:gate:regression",
    "test": "vitest run",
    "clean:build": "node scripts/clean-build.mjs",
    "clean:local": "node scripts/clean-local.mjs",
    "clean:git": "node scripts/clean-git.mjs",
    "clean:repo": "pnpm clean:local && pnpm clean:git",
    "tauri": "tauri",
    "ui:test:visual:update": "playwright test tests/ui --grep @visual --update-snapshots",
    "typecheck": "tsc --noEmit --project tsconfig.ui.json",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:contracts": "vitest run tests/contracts",
    "test:e2e": "playwright test tests",
    "test:e2e:smoke": "playwright test tests/e2e/smoke --grep @smoke",
    "docs:generate": "tsx scripts/docs/generate-openapi.ts && typedoc && node scripts/docs/sync-readme-env.mjs",
    "docs:check": "node scripts/docs/check-doc-drift.mjs",
    "policy:require-tests-docs": "node scripts/ci/require-tests-and-docs.mjs",
    "stryker:run": "stryker run",
    "prepare": "husky",
    "commit": "cz",
    "commitlint": "commitlint",
    "git:guard:branch": "bash scripts/git/guard-branch.sh",
    "git:guard:no-main-push": "bash scripts/git/guard-no-main-push.sh",
    "git:guard:atomic": "bash scripts/git/guard-atomic.sh",
    "git:guard:generated": "bash scripts/git/guard-generated.sh",
    "git:guard:large-files": "bash scripts/git/guard-large-files.sh",
    "git:guard:secrets": "bash scripts/git/guard-secrets.sh",
    "git:guard:all": "pnpm git:guard:branch && pnpm git:guard:atomic && pnpm git:guard:generated && pnpm git:guard:large-files && pnpm git:guard:secrets",
    "git:commit:propose": "node scripts/git/propose-commit-message.mjs",
    "git:session:save": "bash scripts/git/session-save.sh",
    "git:session:resume": "bash scripts/git/session-resume.sh",
    "pr:notes": "bash scripts/git/generate-pr-notes.sh",
    "perf:bundle": "node scripts/perf/bundle-report.mjs",
    "perf:build": "node scripts/perf/measure-build-time.mjs",
    "perf:assets": "bash scripts/perf/check-assets.sh",
    "perf:memory": "node --expose-gc scripts/perf/memory-smoke.mjs",
    "perf:summary": "node scripts/perf/summarize.mjs",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^23.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@axe-core/playwright": "^4.11.0",
    "@faker-js/faker": "^10.1.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.1",
    "@stryker-mutator/core": "^8.6.0",
    "@stryker-mutator/vitest-runner": "^8.6.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "fishery": "^2.3.1",
    "globals": "^16.4.0",
    "jsdom": "^28.1.0",
    "lighthouse": "^12.8.2",
    "msw": "^2.11.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "tsx": "^4.20.5",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.0.7",
    "web-vitals": "^5.1.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
